{
  "name": "velvet-writer",
  "version": "1.3.3",
  "description": "Zero-dependency React rich text editor with glassmorphism UI, slash commands, markdown shortcuts, tables, and dark mode. ~55KB minified. Tiptap & Quill alternative.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./dist/index.css": "./dist/index.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "react",
    "rich-text-editor",
    "wysiwyg",
    "react-editor",
    "contenteditable",
    "text-editor",
    "typescript",
    "dark-mode",
    "notion-editor",
    "slash-commands",
    "tiptap-alternative",
    "quill-alternative",
    "slate-alternative",
    "blog-editor",
    "cms-editor",
    "glassmorphism",
    "velvet-writer",
    "no-dependencies",
    "markdown-editor",
    "table-editor"
  ],
  "bugs": {
    "url": "https://github.com/PoojaGohel/velvet-editor/issues"
  },
  "author": {
    "name": "Pooja Gohel",
    "url": "https://github.com/PoojaGohel"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PoojaGohel/velvet-editor.git"
  },
  "homepage": "https://poojagohel.github.io/velvet-editor/",
  "license": "MIT",
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/PoojaGohel"
    },
    {
      "type": "individual",
      "url": "https://ko-fi.com/PoojaGohel"
    }
  ],
  "scripts": {
    "build": "tsup",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run lint && npm run test && npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "emoji-picker-react": ">=4"
  },
  "peerDependenciesMeta": {
    "emoji-picker-react": {
      "optional": true
    }
  },
  "dependencies": {},
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "emoji-picker-react": "^4.19.1",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "jsdom": "^26.0.0",
    "lucide-react": "^0.378.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tsup": "^8.0.2",
    "typescript": "^5.2.2",
    "typescript-eslint": "^8.19.0",
    "vitest": "^3.0.5"
  },
  "publishConfig": {
    "access": "public"
  }
}